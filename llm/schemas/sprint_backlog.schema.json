{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tickets"
  ],
  "properties": {
    "tickets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "type",
          "priority",
          "severity_score",
          "impact_notes",
          "acceptance_criteria",
          "evidence_quotes",
          "related_labels",
          "related_versions"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "bug",
              "improvement",
              "feature"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "severity_score": {
            "type": "number"
          },
          "impact_notes": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_quotes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
