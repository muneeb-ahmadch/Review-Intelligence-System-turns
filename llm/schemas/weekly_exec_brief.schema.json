{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "week_range",
    "headline",
    "kpi_summary",
    "drivers",
    "risks",
    "recommendations"
  ],
  "properties": {
    "week_range": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.\\.\\d{4}-\\d{2}-\\d{2}$"
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "kpi_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "avg_rating",
        "pct_negative",
        "critical_count"
      ],
      "properties": {
        "avg_rating": {
          "type": "number"
        },
        "pct_negative": {
          "type": "number"
        },
        "critical_count": {
          "type": "integer"
        }
      }
    },
    "drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "impact",
          "evidence_quotes"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "enum": [
              "high",
              "med",
              "low"
            ]
          },
          "evidence_quotes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk",
          "signal",
          "severity"
        ],
        "properties": {
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "signal": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "med",
              "low"
            ]
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action",
          "owner",
          "expected_impact"
        ],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "enum": [
              "PM",
              "Eng",
              "Support"
            ]
          },
          "expected_impact": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
